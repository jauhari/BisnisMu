# Database — Neon PostgreSQL
# Get both URLs from your Neon project dashboard (Connection Details)
# DATABASE_URL: use the "Pooled connection" string, append &pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# DIRECT_URL: use the "Direct connection" string (no -pooler in hostname)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Better Auth — generate a secure random string for production
BETTER_AUTH_SECRET="change-this-to-a-random-secret-in-production"
# In Vercel production env, set this to: https://bisnismu.net
BETTER_AUTH_URL="http://localhost:3000"

# Anthropic — untuk fitur OCR Scan Laporan Harian
# Dapatkan di: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Sentry Error Tracking (optional — set to enable error monitoring)
# Get DSN from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"
SENTRY_AUTH_TOKEN="sntrys_xxx"  # for source map uploads
