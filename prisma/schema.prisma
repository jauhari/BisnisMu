  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  business Business           @relation(fields: [businessId], references: [id], onDelete: Restrict)
  session  PosSessionRecord   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  items    PosCartItem[]
  receipt  PosReceiptRecord?

  @@unique([businessId, transactionNumber])
  @@index([businessId, sessionId])
  @@index([businessId, status])
  @@index([businessId, transactionDate])
  @@map("pos_transactions")
}

model PosCartItem {
  id                String   @id @default(cuid())
  businessId        String   @map("business_id")
  transactionId     String   @map("transaction_id")
  productId         String   @map("product_id")
  quantity          BigInt
  unitPrice         BigInt?  @map("unit_price")
  priceId           String?  @map("price_id")
  discountAmount    BigInt   @default(0) @map("discount_amount")
  discountPercentBps BigInt  @default(0) @map("discount_percent_bps")
  taxAmount         BigInt   @default(0) @map("tax_amount")
  locationId        String?  @map("location_id")
  providerProductId String?  @map("provider_product_id")
  barcode           String?
  createdAt         DateTime @default(now()) @map("created_at")

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  transaction PosTransactionRecord @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  product     Product              @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([businessId, transactionId])
  @@index([businessId, productId])
  @@map("pos_cart_items")
}

model PosReceiptRecord {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  transactionId String   @unique @map("transaction_id")
  receiptNumber String   @map("receipt_number")
  issuedAt      DateTime @map("issued_at")
  totalAmount   BigInt   @map("total_amount")
  paidAmount    BigInt   @map("paid_amount")
  changeAmount  BigInt   @default(0) @map("change_amount")
  createdAt     DateTime @default(now()) @map("created_at")

  business    Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  transaction PosTransactionRecord @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([businessId, receiptNumber])
  @@index([businessId, issuedAt])
  @@map("pos_receipts")
}

enum InstallmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InstallmentScheduleStatus {
  UNPAID
  PARTIAL
  PAID
}

model InstallmentPlan {
  id              String                @id @default(cuid())
  businessId      String                @map("business_id")
  planNumber      String                @map("plan_number")
  customerId      String                @map("customer_id")
  salesOrderId    String?               @map("sales_order_id")
  description     String
  totalAmount     BigInt                @map("total_amount")
  downPayment     BigInt                @default(0) @map("down_payment")
  financedAmount  BigInt                @map("financed_amount")
  tenor           Int
  startDate       DateTime              @map("start_date") @db.Date
  arAccountId     String                @map("ar_account_id")
  status          InstallmentPlanStatus @default(ACTIVE)
  createdByUserId String                @map("created_by_user_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  schedules       InstallmentSchedule[]

  @@unique([businessId, planNumber])
  @@index([businessId, customerId])
  @@index([businessId, status])
  @@map("installment_plans")
}

model InstallmentSchedule {
  id              String                    @id @default(cuid())
  businessId      String                    @map("business_id")
  planId          String                    @map("plan_id")
  sequence        Int
  dueDate         DateTime                  @map("due_date") @db.Date
  amount          BigInt
  paidAmount      BigInt                    @default(0) @map("paid_amount")
  status          InstallmentScheduleStatus @default(UNPAID)
  paidAt          DateTime?                 @map("paid_at")
  postedJournalId String?                   @map("posted_journal_id")
  plan            InstallmentPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([businessId, planId, sequence])
  @@index([businessId, planId])
  @@map("installment_schedules")
}

// ─── Penjualan Harian ──────────────────────────────────────────────────────────

model DailySale {
  id              String   @id @default(cuid())
  businessId      String   @map("business_id")
  saleDate        DateTime @map("sale_date") @db.Date
  cashAccountId   String   @map("cash_account_id")
  description     String?
  totalAmount     BigInt   @default(0) @map("total_amount")
  journalId       String?  @map("journal_id")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  business    Business        @relation(fields: [businessId], references: [id], onDelete: Restrict)
  cashAccount Account         @relation("DailySaleCash", fields: [cashAccountId], references: [id], onDelete: Restrict)
  createdBy   User            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items       DailySaleItem[]

  @@index([businessId, saleDate])
  @@map("daily_sales")
}

model DailySaleItem {
  id               String  @id @default(cuid())
  dailySaleId      String  @map("daily_sale_id")
  revenueAccountId String  @map("revenue_account_id")
  description      String?
  amount           BigInt
  lineNo           Int     @map("line_no")

  dailySale      DailySale        @relation(fields: [dailySaleId], references: [id], onDelete: Cascade)
  revenueAccount Account          @relation("DailySaleRevenue", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  contacts       DailySaleContact[]

  @@index([dailySaleId])
  @@map("daily_sale_items")
}

model DailySaleContact {
  id              String  @id @default(cuid())
  dailySaleItemId String  @map("daily_sale_item_id")
  contactId       String  @map("contact_id")
  amount          BigInt?
  notes           String?

  dailySaleItem DailySaleItem @relation(fields: [dailySaleItemId], references: [id], onDelete: Cascade)
  contact       Contact       @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@unique([dailySaleItemId, contactId])
  @@index([contactId])
  @@map("daily_sale_contacts")
}

// ─── Multi-Unit Organization ────────────────────────────────────────────────────

enum OrgType {
  BUMDES        // Badan Usaha Milik Desa
  KOPERASI      // Koperasi
  HOLDING       // Holding UMKM
  FRANCHISE     // Jaringan waralaba
}

enum OrgRole {
  ORG_OWNER     // Ketua / Direktur — akses penuh semua unit
  ORG_ADMIN     // Sekretaris / Bendahara — kelola semua unit, tidak bisa hapus org
  ORG_VIEWER    // Pengawas / Auditor — read-only semua unit
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        OrgType  @default(BUMDES)
  description String?
  address     String?
  npwpNumber  String?  @map("npwp_number")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  businesses Business[]
  members    OrgMember[]

  @@index([createdById])
  @@map("organizations")
}

model OrgMember {
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           OrgRole
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
  @@map("org_members")
}
