generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlatformRole {
  USER
  SUPER_ADMIN
  SUPPORT_AGENT
  FINANCE_ADMIN
  DEVELOPER
}

enum AccountGroupCode {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COGS
  EXPENSE
  OTHER_EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalSide {
  DEBIT
  CREDIT
}

enum JournalStatus {
  POSTED
  REVERSED
}

enum BusinessType {
  UMKM
  BUMDES
  PERORANGAN
  CV
  UD
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BusinessMemberRole {
  OWNER
  ADMIN
  ACCOUNTANT
  CASHIER
  VIEWER
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
}

enum BeginningBalanceStatus {
  DRAFT
  POSTED
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
  OTHER
}

enum ContactCategory {
  INDIVIDUAL
  INSTANSI
}

enum CashTransactionType {
  CASH_IN
  CASH_OUT
  TRANSFER
}

enum CashTransactionStatus {
  DRAFT
  POSTED
  VOID
}

enum RevenueType {
  TICKET
  PACKAGE
  PARKING
  RENTAL
  TENANT_RENT
  SERVICE
  PRODUCT_SALE
  OTHER_REVENUE
}

enum RevenueTransactionStatus {
  DRAFT
  POSTED
  VOID
}

enum RevenuePricingType {
  STANDARD
  TIER
  DAILY
  WEEKEND
  SEASONAL
  PACKAGE
}

enum TourismRentalType {
  GAZEBO
  AREA
  EVENT
}

enum VisitorTransactionSource {
  ENTRANCE_TICKET
  PACKAGE_TICKET
  PARKING_FEE
  GAZEBO_RENTAL
  AREA_RENTAL
  TENANT_RENTAL
  EVENT_RENTAL
}

enum VisitorTransactionStatus {
  DRAFT
  PAID
  VOID
}

enum ReceivablePayableStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentDirection {
  CUSTOMER_PAYMENT
  VENDOR_PAYMENT
}

enum AdjustmentNoteType {
  CREDIT_NOTE
  DEBIT_NOTE
}

enum FloatProvider {
  BUKUWARUNG
  FASTPAY
  PAYFAZZ
  SHOPEEPAY
  LINKAJA
  CUSTOM
}

enum FloatTransactionType {
  TOPUP
  CONSUME
  TRANSFER
  ADJUSTMENT
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum ProductPriceType {
  BUY
  SELL
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER
  SALE
  PURCHASE
  DIGITAL_CONSUMPTION
}

enum InventoryCostHistorySource {
  PRICE_UPDATE
  STOCK_IN
  DIGITAL_PROVIDER
}

enum PaymentMethodType {
  CASH
  BANK
  QRIS
  FLOAT
  CUSTOMER_WALLET
  ACCOUNTS_RECEIVABLE
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum WalletTransactionType {
  TOPUP
  SPEND
  REFUND
  ADJUSTMENT
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  VOID
}

enum AuditAction {
  JOURNAL_POSTED
  JOURNAL_POST_REJECTED
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  ACCOUNT_DEACTIVATED
  ACCOUNT_DELETED
  CHART_OF_ACCOUNTS_SEEDED
  BUSINESS_CREATED
  BUSINESS_SETTINGS_UPDATED
  FISCAL_PERIOD_OPENED
  FISCAL_PERIOD_CLOSED
  FISCAL_PERIOD_REOPENED
  BEGINNING_BALANCE_SAVED
  BEGINNING_BALANCE_POSTED
  CONTACT_CREATED
  CASH_TRANSACTION_DRAFTED
  CASH_TRANSACTION_UPDATED
  CASH_TRANSACTION_POSTED
  CASH_TRANSACTION_VOIDED
  CASH_JOURNAL_PREVIEWED
  REPORT_GENERATED
  REVENUE_CATEGORY_CREATED
  REVENUE_ITEM_CREATED
  REVENUE_PACKAGE_CREATED
  REVENUE_PRICING_CREATED
  REVENUE_TRANSACTION_DRAFTED
  REVENUE_TRANSACTION_POSTED
  REVENUE_TRANSACTION_VOIDED
  ATTRACTION_CREATED
  TICKET_TYPE_CREATED
  TICKET_PACKAGE_CREATED
  PARKING_SERVICE_CREATED
  RENTAL_SERVICE_CREATED
  TENANT_RENTAL_CREATED
  VISITOR_TRANSACTION_DRAFTED
  VISITOR_TRANSACTION_PAID
  VISITOR_TRANSACTION_VOIDED
  TICKET_VALIDATED
  CUSTOMER_CREATED
  VENDOR_CREATED
  INVOICE_DRAFTED
  INVOICE_POSTED
  BILL_DRAFTED
  BILL_POSTED
  PAYMENT_RECORDED
  CREDIT_NOTE_APPLIED
  DEBIT_NOTE_APPLIED
  FLOAT_ACCOUNT_CREATED
  FLOAT_TOPUP_POSTED
  FLOAT_CONSUMPTION_POSTED
  FLOAT_TRANSFER_POSTED
  FLOAT_ADJUSTMENT_POSTED
  FLOAT_BALANCE_SNAPSHOT_CREATED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_PRICE_UPDATED
  INVENTORY_STOCK_IN
  INVENTORY_STOCK_OUT
  INVENTORY_ADJUSTED
  INVENTORY_TRANSFERRED
  DIGITAL_PRODUCT_CONSUMED
  PURCHASE_ORDER_CREATED
  PURCHASE_ORDER_APPROVED
  PURCHASE_ORDER_RECEIVED
  PURCHASE_RETURN_CREATED
  PURCHASE_VENDOR_BILL_GENERATED
  CASH_SESSION_OPENED
  CASH_SESSION_CLOSED
  CASH_MOVEMENT_RECORDED
  CASH_TRANSFER_RECORDED
  CASH_RECONCILED
  POS_SESSION_OPENED
  POS_SESSION_CLOSED
  POS_CART_UPDATED
  POS_TRANSACTION_CHECKED_OUT
  POS_PAYMENT_ALLOCATED
  POS_CHANGE_SAVED_TO_DEPOSIT
  POS_TRANSACTION_VOIDED
  SALES_ORDER_CREATED
  SALES_ORDER_CONFIRMED
  SALES_PAYMENT_ALLOCATED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING_BALANCE
  SALE_RECEIPT
  CUSTOMER_DEPOSIT
  EXPENSE
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT
  CLOSING
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosTransactionStatus {
  DRAFT
  CHECKOUT
  PARTIALLY_PAID
  PAID
  VOID
}

model Business {
  id              String         @id @default(cuid())
  name            String
  type            BusinessType   @default(UMKM)
  status          BusinessStatus @default(ACTIVE)
  npwpNumber      String?        @map("npwp_number")
  address         String?
  fiscalYearStart Int            @default(1) @map("fiscal_year_start")
  currency        String         @default("IDR")
  settings        Json?
  createdByUserId String         @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  accounts                   Account[]
  fiscalPeriods              FiscalPeriod[]
  journals                   JournalEntry[]
  auditLogs                  AuditLog[]
  beginningBalances          BeginningBalance[]
  contacts                   Contact[]
  cashTransactions           CashTransaction[]
  revenueCategories          RevenueCategory[]
  revenueItems               RevenueItem[]
  revenuePackages            RevenuePackage[]
  revenuePricings            RevenuePricing[]
  revenueTransactions        RevenueTransaction[]
  attractions                Attraction[]
  ticketTypes                TicketType[]
  ticketPackages             TicketPackage[]
  parkingServices            ParkingService[]
  rentalServices             RentalService[]
  tenantRentals              TenantRental[]
  visitorTransactions        VisitorTransaction[]
  customers                  Customer[]
  vendors                    Vendor[]
  invoices                   Invoice[]
  bills                      Bill[]
  payments                   Payment[]
  customerWallets            CustomerWallet[]
  paymentTransactions        PaymentTransaction[]
  receivables                Receivable[]
  customerWalletTransactions CustomerWalletTransaction[]
  paymentMethods             PaymentMethod[]
  adjustmentNotes            AdjustmentNote[]
  floatAccounts              FloatAccount[]
  floatTransactions          FloatTransaction[]
  floatSnapshots             FloatBalanceSnapshot[]
  productCategories          ProductCategory[]
  products                   Product[]
  productPrices              ProductPrice[]
  inventoryBalances          InventoryBalance[]
  inventoryMovements         InventoryMovement[]
  productCostHistories       ProductCostHistory[]
  providerProducts           ProviderProduct[]
  salesOrders                SalesOrder[]
  salesOrderItems            SalesOrderItem[]
  paymentAllocations         PaymentAllocation[]
  purchaseOrders             PurchaseOrder[]
  purchaseOrderItems         PurchaseOrderItem[]
  purchaseReceipts           PurchaseReceipt[]
  purchaseReturns            PurchaseReturn[]
  cashDrawers                CashDrawer[]
  cashSessions               CashSessionRecord[]
  cashMovements              CashMovementRecord[]
  cashReconciliations        CashReconciliationRecord[]
  posTerminals               PosTerminal[]
  posSessions                PosSessionRecord[]
  posTransactions            PosTransactionRecord[]
  posCartItems               PosCartItem[]
  posReceipts                PosReceiptRecord[]
  members                    BusinessMember[]
  dailySales                 DailySale[]

  // Multi-Unit Organization (additive, opsional) — satu Business hanya milik satu Organization.
  organizationId             String?                    @map("organization_id")
  organization               Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([organizationId])
  @@map("businesses")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false) @map("email_verified")
  image         String?
  platformRole  PlatformRole @default(USER) @map("platform_role")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  sessions          Session[]
  accounts          AuthAccount[]
  memberships       BusinessMember[]
  godModeAuditLogs  GodModeAuditLog[]
  dailySales        DailySale[]
  orgMemberships    OrgMember[]

  @@map("users")
}

model GodModeAuditLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  detail     Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
  @@map("god_mode_audit_logs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  activeBusinessId String? @map("active_business_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model BusinessMember {
  id         String             @id @default(cuid())
  businessId String             @map("business_id")
  userId     String             @map("user_id")
  role       BusinessMemberRole
  isActive   Boolean            @default(true) @map("is_active")
  invitedBy  String?            @map("invited_by")
  invitedAt  DateTime?          @map("invited_at")
  joinedAt   DateTime           @default(now()) @map("joined_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId, isActive])
  @@index([businessId, role])
  @@map("business_members")
}

model AuthAccount {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("auth_accounts")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([identifier, value])
  @@map("verification_tokens")
}

model Account {
  id               String           @id @default(cuid())
  businessId       String           @map("business_id")
  code             String
  name             String
  groupCode        AccountGroupCode @map("group_code")
  subtype          String?
  description      String?
  normalBalance    NormalBalance    @map("normal_balance")
  parentId         String?          @map("parent_id")
  parentCode       String?          @map("parent_code")
  isSystem         Boolean          @default(false) @map("is_system")
  isPostingAllowed Boolean          @default(true) @map("is_posting_allowed")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  business                             Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  parent                               Account?             @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                             Account[]            @relation("AccountHierarchy")
  lines                                JournalLine[]
  beginningBalances                    BeginningBalance[]
  cashAsPrimary                        CashTransaction[]    @relation("CashPrimaryAccount")
  cashAsDestination                    CashTransaction[]    @relation("CashDestinationAccount")
  cashAsCategory                       CashTransaction[]    @relation("CashCategoryAccount")
  revenueCashTransactions              RevenueTransaction[] @relation("RevenueCashAccount")
  revenueCategories                    RevenueCategory[]    @relation("RevenueAccount")
  invoiceArAccounts                    Invoice[]            @relation("InvoiceArAccount")
  invoiceRevenueAccounts               Invoice[]            @relation("InvoiceRevenueAccount")
  billApAccounts                       Bill[]               @relation("BillApAccount")
  billExpenseAccounts                  Bill[]               @relation("BillExpenseAccount")
  paymentCashAccounts                  Payment[]            @relation("PaymentCashAccount")
  depositLiabilityWallets              CustomerWallet[]     @relation("DepositLiabilityAccount")
  paymentMethodAccounts                PaymentMethod[]      @relation("PaymentMethodAccount")
  paymentRevenueSettlementTransactions PaymentTransaction[] @relation("PaymentRevenueSettlementAccount")
  paymentArTransactions                PaymentTransaction[] @relation("PaymentArAccount")
  paymentAllocationAccounts            PaymentAllocation[]  @relation("PaymentAllocationAccount")
  paymentReceivableAccounts            Receivable[]         @relation("ReceivableArAccount")
  floatAssetAccounts                   FloatAccount[]       @relation("FloatAssetAccount")
  floatOffsetAccounts                  FloatAccount[]       @relation("FloatOffsetAccount")
  floatCashAccounts                    FloatTransaction[]   @relation("FloatCashAccount")
  dailySalesAsCash                     DailySale[]          @relation("DailySaleCash")
  dailySaleItemsAsRevenue              DailySaleItem[]      @relation("DailySaleRevenue")
  productInventoryAccounts             Product[]            @relation("ProductInventoryAccount")
  productCogsAccounts                  Product[]            @relation("ProductCogsAccount")
  productRevenueAccounts               Product[]            @relation("ProductRevenueAccount")
  cashDrawerAccounts                   CashDrawer[]         @relation("CashDrawerCashAccount")
  cashSessionAccounts                  CashSessionRecord[]  @relation("CashSessionCashAccount")
  cashMovementAccounts                 CashMovementRecord[] @relation("CashMovementCashAccount")
  cashMovementDestinationAccounts      CashMovementRecord[] @relation("CashMovementDestinationAccount")

  @@unique([businessId, code])
  @@index([businessId, parentId])
  @@index([businessId, parentCode])
  @@index([businessId, groupCode])
  @@map("accounts")
}

model FiscalPeriod {
  id               String             @id @default(cuid())
  businessId       String             @map("business_id")
  name             String
  fiscalYear       Int                @map("fiscal_year")
  startsOn         DateTime           @map("starts_on") @db.Date
  endsOn           DateTime           @map("ends_on") @db.Date
  status           FiscalPeriodStatus @default(OPEN)
  isClosed         Boolean            @default(false) @map("is_closed")
  closedAt         DateTime?          @map("closed_at")
  closedByUserId   String?            @map("closed_by_user_id")
  reopenedAt       DateTime?          @map("reopened_at")
  reopenedByUserId String?            @map("reopened_by_user_id")
  reopenReason     String?            @map("reopen_reason")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  business Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  journals JournalEntry[]

  @@unique([businessId, fiscalYear])
  @@index([businessId, startsOn, endsOn, status])
  @@index([businessId, isClosed])
  @@map("fiscal_periods")
}

model JournalEntry {
  id              String        @id @default(cuid())
  businessId      String        @map("business_id")
  fiscalPeriodId  String        @map("fiscal_period_id")
  journalNumber   String        @map("journal_number")
  transactionDate DateTime      @map("transaction_date") @db.Date
  source          String
  sourceId        String?       @map("source_id")
  description     String
  status          JournalStatus @default(POSTED)
  totalDebit      BigInt        @map("total_debit")
  totalCredit     BigInt        @map("total_credit")
  postedAt        DateTime      @default(now()) @map("posted_at")
  postedByUserId  String        @map("posted_by_user_id")
  idempotencyKey  String?       @map("idempotency_key")
  reversedById    String?       @unique @map("reversed_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Restrict)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict)
  lines        JournalLine[]
  reversedBy   JournalEntry? @relation("JournalReversal", fields: [reversedById], references: [id], onDelete: Restrict)
  reverses     JournalEntry? @relation("JournalReversal")

  @@unique([businessId, journalNumber])
  @@unique([businessId, idempotencyKey])
  @@index([businessId, transactionDate])
  @@index([businessId, source, sourceId])
  @@map("journal_entries")
}

model JournalLine {
  id         String      @id @default(cuid())
  businessId String      @map("business_id")
  journalId  String      @map("journal_id")
  accountId  String      @map("account_id")
  side       JournalSide
  amount     BigInt
  memo       String?
  lineNo     Int         @map("line_no")
  createdAt  DateTime    @default(now()) @map("created_at")

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Restrict)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([journalId, lineNo])
  @@index([businessId, accountId])
  @@index([businessId, journalId])
  @@map("journal_lines")
}

model Contact {
  id         String          @id @default(cuid())
  businessId String          @map("business_id")
  name       String
  type       ContactType     @default(OTHER)
  category   ContactCategory @default(INDIVIDUAL)
  picName    String?         @map("pic_name")
  email      String?
  phone      String?
  address    String?
  isActive   Boolean         @default(true) @map("is_active")
  // Loyalty
  totalVisits   Int    @default(0) @map("total_visits")
  totalRevenue  BigInt @default(0) @map("total_revenue")
  loyaltyPoints Int    @default(0) @map("loyalty_points")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  business          Business           @relation(fields: [businessId], references: [id], onDelete: Restrict)
  cashTransactions  CashTransaction[]
  dailySaleContacts DailySaleContact[]

  @@index([businessId, type])
  @@index([businessId, name])
  @@index([businessId, phone])
  @@map("contacts")
}

model CashTransaction {
  id                   String                @id @default(cuid())
  businessId           String                @map("business_id")
  transactionNumber    String                @map("transaction_number")
  type                 CashTransactionType
  status               CashTransactionStatus @default(DRAFT)
  transactionDate      DateTime              @map("transaction_date") @db.Date
  cashAccountId        String                @map("cash_account_id")
  destinationAccountId String?               @map("destination_account_id")
  categoryAccountId    String?               @map("category_account_id")
  contactId            String?               @map("contact_id")
  amount               BigInt
  description          String
  paymentMethod        String?               @map("payment_method")
  referenceNumber      String?               @map("reference_number")
  attachmentKey        String?               @map("attachment_key")
  tags                 String[]              @default([])
  postedJournalId      String?               @map("posted_journal_id")
  voidJournalId        String?               @map("void_journal_id")
  voidReason           String?               @map("void_reason")
  createdByUserId      String                @map("created_by_user_id")
  postedByUserId       String?               @map("posted_by_user_id")
  voidedByUserId       String?               @map("voided_by_user_id")
  postedAt             DateTime?             @map("posted_at")
  voidedAt             DateTime?             @map("voided_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  business           Business @relation(fields: [businessId], references: [id], onDelete: Restrict)
  cashAccount        Account  @relation("CashPrimaryAccount", fields: [cashAccountId], references: [id], onDelete: Restrict)
  destinationAccount Account? @relation("CashDestinationAccount", fields: [destinationAccountId], references: [id], onDelete: Restrict)
  categoryAccount    Account? @relation("CashCategoryAccount", fields: [categoryAccountId], references: [id], onDelete: Restrict)
  contact            Contact? @relation(fields: [contactId], references: [id], onDelete: Restrict)

  @@unique([businessId, transactionNumber])
  @@index([businessId, transactionDate])
  @@index([businessId, status])
  @@index([businessId, type])
  @@index([businessId, contactId])
  @@map("cash_transactions")
}

model RevenueCategory {
  id               String      @id @default(cuid())
  businessId       String      @map("business_id")
  name             String
  type             RevenueType
  revenueAccountId String      @map("revenue_account_id")
  description      String?
  isActive         Boolean     @default(true) @map("is_active")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  business       Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  revenueAccount Account              @relation("RevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  items          RevenueItem[]
  packages       RevenuePackage[]
  transactions   RevenueTransaction[]

  @@index([businessId, type])
  @@index([businessId, revenueAccountId])
  @@map("revenue_categories")
}

model RevenueItem {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  categoryId  String   @map("category_id")
  name        String
  sku         String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business     Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
  category     RevenueCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  pricings     RevenuePricing[]
  transactions RevenueTransaction[]

  @@unique([businessId, sku])
  @@index([businessId, categoryId])
  @@map("revenue_items")
}

model RevenuePackage {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  categoryId  String   @map("category_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business     Business             @relation(fields: [businessId], references: [id], onDelete: Restrict)
