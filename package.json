  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "next dev --port 3333",
    "build": "prisma generate && next build",
    "start": "npm run prisma:migrations:check && next start",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:migrations:check": "node scripts/check-prisma-migrations.mjs",
    "prisma:migrations:verify": "node scripts/verify-prisma-migrations.mjs",
    "db:seed:dev": "node scripts/seed-dev-owner.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@better-auth/core": "^1.6.13",
    "@better-auth/prisma-adapter": "^1.6.13",
    "@hookform/resolvers": "^5.0.0",
    "@prisma/client": "^6.8.2",
    "@sentry/nextjs": "^10.56.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.0.0",
    "argon2": "^0.44.0",
    "better-auth": "^1.6.13",
    "framer-motion": "^12.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "kysely": "^0.28.8",
    "lucide-react": "^0.468.0",
