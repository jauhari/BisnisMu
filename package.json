    "xlsx": "^0.18.5",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
